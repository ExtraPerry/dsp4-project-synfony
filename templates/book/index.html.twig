{% extends 'base.html.twig' %}

{% block title %}Catalog - LibraryHub{% endblock %}

{% block body %}
<h1>Book Catalog</h1>

<form method="get" action="{{ path('app_book_index') }}" class="search-form">
    <div class="search-row">
        <div class="form-group">
            <label for="searchQuery">Title</label>
            <input type="text" id="searchQuery" name="q" value="{{ currentQuery }}" placeholder="Search by title..." class="form-control">
        </div>
        <div class="form-group">
            <label for="searchAuthor">Author</label>
            <input type="text" id="searchAuthor" name="author" value="{{ currentAuthor }}" placeholder="Search by author..." class="form-control">
        </div>
        <div class="form-group">
            <label for="searchCategory">Category</label>
            <select id="searchCategory" name="category" class="form-control">
                <option value="">All Categories</option>
                {% for category in categories %}
                    <option value="{{ category.id }}" {{ currentCategory == category.id ? 'selected' : '' }}>{{ category.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="form-group search-btn-group">
            <button type="submit" class="btn btn-primary">Search</button>
            <a href="{{ path('app_book_index') }}" class="btn btn-secondary">Reset</a>
        </div>
    </div>
</form>

{% if books|length > 0 %}
    <p class="results-count">{{ books|length }} book(s) found</p>
    <div class="book-grid">
        {% for book in books %}
            <div class="card">
                <div class="card-image">
                    {% if book.coverImage %}
                        <img src="{{ book.coverImage }}" alt="{{ book.title }}">
                    {% else %}
                        <div class="placeholder-cover">📖</div>
                    {% endif %}
                </div>
                <div class="card-body">
                    <h3 class="card-title">
                        <a href="{{ path('app_book_show', {id: book.id}) }}">{{ book.title }}</a>
                    </h3>
                    <p class="card-meta">
                        {% for author in book.authors %}
                            {{ author.fullName }}{% if not loop.last %}, {% endif %}
                        {% endfor %}
                    </p>
                    {% if book.categories|length > 0 %}
                        <div class="tags">
                            {% for category in book.categories %}
                                <span class="tag">{{ category.name }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                    {% if book.averageRating %}
                        <div class="stars">
                            {% for i in 1..5 %}
                                <span class="star {{ i <= book.averageRating ? 'filled' : '' }}">★</span>
                            {% endfor %}
                            <span class="rating-value">{{ book.averageRating }}/5</span>
                        </div>
                    {% endif %}
                    <p class="stock-info">
                        {% if book.stockQuantity > 0 %}
                            <span class="in-stock">{{ book.stockQuantity }} available</span>
                        {% else %}
                            <span class="out-of-stock">Out of stock</span>
                        {% endif %}
                    </p>
                </div>
            </div>
        {% endfor %}
    </div>
{% else %}
    <p class="no-results">No books found matching your criteria.</p>
{% endif %}
{% endblock %}
