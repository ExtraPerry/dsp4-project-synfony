{% extends 'base.html.twig' %}
{% block title %}Manage Users - Admin{% endblock %}
{% block body %}
<div class="breadcrumb"><a href="{{ path('app_admin_dashboard') }}">Admin</a> &raquo; Users</div>
<h1>Manage Users</h1>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Current Roles</th>
            <th>Change Role</th>
        </tr>
    </thead>
    <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.fullName }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.roles|join(', ') }}</td>
                <td>
                    <form method="post" action="{{ path('app_admin_user_role', {id: user.id}) }}" class="inline-form role-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('role' ~ user.id) }}">
                        <select name="role" class="form-control form-control-sm">
                            <option value="ROLE_USER" {{ 'ROLE_ADMIN' not in user.roles and 'ROLE_LIBRARIAN' not in user.roles ? 'selected' : '' }}>User</option>
                            <option value="ROLE_LIBRARIAN" {{ 'ROLE_LIBRARIAN' in user.roles and 'ROLE_ADMIN' not in user.roles ? 'selected' : '' }}>Librarian</option>
                            <option value="ROLE_ADMIN" {{ 'ROLE_ADMIN' in user.roles ? 'selected' : '' }}>Admin</option>
                        </select>
                        <button type="submit" class="btn btn-secondary btn-sm">Update</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="4">No users found.</td></tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
