{% extends 'base.html.twig' %}

{% block title %}Manage Languages - LibraryHub{% endblock %}

{% block body %}
<div class="breadcrumb">
    <a href="{{ path('app_librarian_dashboard') }}">Librarian</a> &raquo; Languages
</div>

<div class="page-header">
    <h1>Manage Languages</h1>
    <a href="{{ path('app_librarian_language_new') }}" class="btn btn-primary">Add New Language</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Code</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for language in languages %}
            <tr>
                <td>{{ language.name }}</td>
                <td>{{ language.code }}</td>
                <td class="actions">
                    <a href="{{ path('app_librarian_language_edit', {id: language.id}) }}" class="btn btn-secondary btn-sm">Edit</a>
                    <form method="post" action="{{ path('app_librarian_language_delete', {id: language.id}) }}" class="inline-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ language.id) }}">
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete?')">Delete</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="3">No languages found.</td></tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
