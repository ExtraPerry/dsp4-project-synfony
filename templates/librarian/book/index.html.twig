{% extends 'base.html.twig' %}

{% block title %}Manage Books - LibraryHub{% endblock %}

{% block body %}
<div class="breadcrumb">
    <a href="{{ path('app_librarian_dashboard') }}">Librarian</a> &raquo; Books
</div>

<div class="page-header">
    <h1>Manage Books</h1>
    <a href="{{ path('app_librarian_book_new') }}" class="btn btn-primary">Add New Book</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Author(s)</th>
            <th>ISBN</th>
            <th>Stock</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for book in books %}
            <tr>
                <td>{{ book.title }}</td>
                <td>
                    {% for author in book.authors %}
                        {{ author.fullName }}{% if not loop.last %}, {% endif %}
                    {% endfor %}
                </td>
                <td>{{ book.isbn ?? '-' }}</td>
                <td>{{ book.stockQuantity }}</td>
                <td class="actions">
                    <a href="{{ path('app_librarian_book_edit', {id: book.id}) }}" class="btn btn-secondary btn-sm">Edit</a>
                    <form method="post" action="{{ path('app_librarian_book_delete', {id: book.id}) }}" class="inline-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this book?')">Delete</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="5">No books found.</td></tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
