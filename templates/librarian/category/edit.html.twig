{% extends 'base.html.twig' %}

{% block title %}Edit Category - LibraryHub{% endblock %}

{% block body %}
<div class="breadcrumb">
    <a href="{{ path('app_librarian_dashboard') }}">Librarian</a> &raquo;
    <a href="{{ path('app_librarian_categories') }}">Categories</a> &raquo; Edit
</div>

<div class="form-container">
    <h1>Edit: {{ category.name }}</h1>
    {{ form_start(form, {'attr': {'class': 'form'}}) }}
        <div class="form-group">
            {{ form_label(form.name) }}
            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.name) }}
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="{{ path('app_librarian_categories') }}" class="btn btn-secondary">Cancel</a>
    {{ form_end(form) }}
</div>
{% endblock %}
