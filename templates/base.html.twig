<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}LibraryHub{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📚</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <nav class="navbar">
            <div class="container navbar-container">
                <a href="{{ path('app_home') }}" class="navbar-brand">LibraryHub</a>
                <div class="navbar-links">
                    <a href="{{ path('app_home') }}">Home</a>
                    <a href="{{ path('app_book_index') }}">Catalog</a>
                    {% if app.user %}
                        <a href="{{ path('app_profile') }}">Profile</a>
                        {% if is_granted('ROLE_LIBRARIAN') %}
                            <a href="{{ path('app_librarian_dashboard') }}">Librarian</a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_dashboard') }}">Admin</a>
                        {% endif %}
                        <a href="{{ path('app_logout') }}">Logout</a>
                    {% else %}
                        <a href="{{ path('app_login') }}">Login</a>
                        <a href="{{ path('app_register') }}">Register</a>
                    {% endif %}
                </div>
            </div>
        </nav>

        <main class="container main-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="footer">
            <div class="container">
                <p>&copy; {{ "now"|date("Y") }} LibraryHub. Pretend copyright HERE :I.</p>
            </div>
        </footer>
    </body>
</html>
