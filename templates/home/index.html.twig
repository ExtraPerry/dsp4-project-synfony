{% extends 'base.html.twig' %}

{% block title %}Home - LibraryHub{% endblock %}

{% block body %}
<section class="hero">
    <h1>Welcome to LibraryHub</h1>
    <p>Discover, reserve, and review books from our extensive catalog.</p>
    <a href="{{ path('app_book_index') }}" class="btn btn-primary">Browse Catalog</a>
</section>

<section class="section">
    <h2>Latest Books</h2>
    {% if latestBooks|length > 0 %}
        <div class="book-grid">
            {% for book in latestBooks %}
                <div class="card">
                    <div class="card-image">
                        {% if book.coverImage %}
                            <img src="{{ book.coverImage }}" alt="{{ book.title }}">
                        {% else %}
                            <div class="placeholder-cover">📖</div>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">
                            <a href="{{ path('app_book_show', {id: book.id}) }}">{{ book.title }}</a>
                        </h3>
                        <p class="card-meta">
                            {% for author in book.authors %}
                                {{ author.fullName }}{% if not loop.last %}, {% endif %}
                            {% endfor %}
                        </p>
                        {% if book.averageRating %}
                            <div class="stars">
                                {% for i in 1..5 %}
                                    <span class="star {{ i <= book.averageRating ? 'filled' : '' }}">★</span>
                                {% endfor %}
                                <span class="rating-value">{{ book.averageRating }}/5</span>
                            </div>
                        {% endif %}
                        <p class="stock-info">
                            {% if book.stockQuantity > 0 %}
                                <span class="in-stock">{{ book.stockQuantity }} available</span>
                            {% else %}
                                <span class="out-of-stock">Out of stock</span>
                            {% endif %}
                        </p>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p>No books available yet.</p>
    {% endif %}
</section>
{% endblock %}
