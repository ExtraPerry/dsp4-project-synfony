{% extends 'base.html.twig' %}

{% block title %}My Profile - LibraryHub{% endblock %}

{% block body %}
<h1>My Profile</h1>

<div class="profile-info card">
    <div class="card-body">
        <h2>{{ user.fullName }}</h2>
        <p><strong>Email:</strong> {{ user.email }}</p>
        <p><strong>Roles:</strong> {{ user.roles|join(', ') }}</p>
    </div>
</div>

<section class="section">
    <h2>My Reservations</h2>
    {% if reservations|length > 0 %}
        <table class="table">
            <thead>
                <tr>
                    <th>Book</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for reservation in reservations %}
                    <tr>
                        <td>
                            <a href="{{ path('app_book_show', {id: reservation.book.id}) }}">
                                {{ reservation.book.title }}
                            </a>
                        </td>
                        <td>{{ reservation.startDate|date('M j, Y') }}</td>
                        <td>{{ reservation.endDate|date('M j, Y') }}</td>
                        <td>
                            <span class="status-badge status-{{ reservation.status.value }}">
                                {{ reservation.status.value|capitalize }}
                            </span>
                        </td>
                        <td>
                            {% if reservation.status.value == 'pending' %}
                                <form method="post" action="{{ path('app_reservation_cancel', {id: reservation.id}) }}" class="inline-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Cancel this reservation?')">Cancel</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>No reservations yet.</p>
    {% endif %}
</section>

<section class="section">
    <h2>My Favorites</h2>
    {% if favoriteBooks|length > 0 %}
        <div class="book-grid">
            {% for book in favoriteBooks %}
                <div class="card">
                    <div class="card-image">
                        {% if book.coverImage %}
                            <img src="{{ book.coverImage }}" alt="{{ book.title }}">
                        {% else %}
                            <div class="placeholder-cover">📖</div>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">
                            <a href="{{ path('app_book_show', {id: book.id}) }}">{{ book.title }}</a>
                        </h3>
                        <form method="post" action="{{ path('app_favorite_toggle', {bookId: book.id}) }}" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('favorite' ~ book.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p>No favorite books yet. Browse the <a href="{{ path('app_book_index') }}">catalog</a> to find books you love!</p>
    {% endif %}
</section>
{% endblock %}
